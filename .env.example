# TasteTrail environment. Copy to .env and fill in real values.
# .env is gitignored — never commit it.

# --- Turso / libSQL --------------------------------------------------------
# Create a new database via Turso dashboard or CLI: turso db create tastetrail
TURSO_DATABASE_URL=libsql://tastetrail-agsternthal.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- Resend (passwordless email) -------------------------------------------
RESEND_API_KEY=re_your_resend_key
AUTH_EMAIL_FROM=TasteTrail <onboarding@resend.dev>

# --- Session signing -------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=your-session-secret-min-32-chars

# --- Mapbox ----------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token

# --- App URL ---------------------------------------------------------------
# localhost for dev. Use Vercel URL for phone GPS testing (HTTPS required).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google Places (server-side; seed pull + photo proxy) -----------------
GOOGLE_PLACES_API_KEY=your-google-places-key
